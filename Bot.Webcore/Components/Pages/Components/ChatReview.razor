@inject BotService Bot
@using Bot.Webcore.Services
@using MinecraftProtoNet.Core.Dtos
@implements IDisposable

<div class="bg-slate-900/40 backdrop-blur-2xl rounded-3xl border border-slate-800/80 shadow-2xl overflow-hidden flex flex-col h-full">
    <div class="px-6 py-4 border-b border-slate-800/60 flex items-center justify-between bg-slate-900/20">
        <div class="flex items-center gap-3">
            <div class="flex px-2 py-1 bg-emerald-500/10 rounded-lg border border-emerald-500/20">
                <i class="ph-duotone ph-chats text-xl text-emerald-400"></i>
            </div>
            <h2 class="text-lg font-bold text-slate-100 tracking-tight">Signal Review</h2>
        </div>
        
        <label class="flex items-center gap-3 cursor-pointer group">
            <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest group-hover:text-slate-400 transition-colors">Redirect Chat</span>
            <div class="relative">
                <input type="checkbox" @bind="Bot.State.BotSettings.RedirectChat" class="sr-only peer" />
                <div class="w-10 h-5 bg-slate-800 rounded-full border border-slate-700 peer-checked:bg-emerald-500/20 peer-checked:border-emerald-500/40 transition-all shadow-inner"></div>
                <div class="absolute left-1 top-1 w-3 h-3 bg-slate-500 rounded-full transition-all peer-checked:left-6 peer-checked:bg-emerald-400 shadow-md"></div>
            </div>
        </label>
    </div>

    <div class="p-5 flex-1 flex flex-col min-h-0">
        @if (!Bot.IsConnected)
        {
            <div class="flex flex-col items-center justify-center py-12 text-slate-600">
                <div class="w-16 h-16 rounded-full bg-slate-800/30 flex items-center justify-center mb-4 border border-slate-800/50">
                    <i class="ph-duotone ph-chat-centered-dots text-3xl opacity-20"></i>
                </div>
                <p class="font-medium text-sm">Awaiting connection...</p>
            </div>
        }
        else if (Bot.PendingRedirectedChat.IsEmpty)
        {
            <div class="flex-1 flex flex-col items-center justify-center py-10 opacity-30 italic">
                <p class="text-xs font-bold uppercase tracking-widest">No signals for review</p>
            </div>
        }
        else
        {
            <div class="space-y-3 overflow-y-auto pr-2 custom-scrollbar flex-1">
                @foreach (var msg in Bot.PendingRedirectedChat.ToList())
                {
                    <div class="p-4 bg-slate-950/40 rounded-2xl border border-slate-800/60 flex flex-col gap-3 group hover:border-emerald-500/20 transition-all shadow-inner">
                        <div class="text-sm text-slate-200 leading-relaxed font-medium break-words">
                            @msg.Message
                        </div>
                        <div class="flex items-center justify-between pt-2 border-t border-slate-800/40">
                            <span class="text-[10px] font-black text-slate-600 tabular-nums uppercase">
                                <i class="ph-duotone ph-clock mr-1"></i>
                                @DateTimeOffset.FromUnixTimeMilliseconds(msg.Timestamp).LocalDateTime.ToString("T")
                            </span>
                            <div class="flex gap-2">
                                <button @onclick="() => Dismiss(msg)" 
                                        class="px-3 py-1 bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 text-[10px] font-black uppercase tracking-tighter rounded-lg border border-rose-500/20 transition-all">
                                    Dismiss
                                </button>
                                <button @onclick="() => Send(msg)" 
                                        class="px-3 py-1 bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 text-[10px] font-black uppercase tracking-tighter rounded-lg border border-emerald-500/20 transition-all shadow-lg shadow-emerald-500/5">
                                    Relay to Core
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Bot.OnStateChanged += OnBotStateChanged;
    }

    private void OnBotStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task Send(ChatRedirectRequest msg)
    {
        await Bot.SendRedirectedChatAsync(msg);
        Bot.DismissRedirectedChat(msg);
    }

    private void Dismiss(ChatRedirectRequest msg)
    {
        Bot.DismissRedirectedChat(msg);
    }

    public void Dispose()
    {
        Bot.OnStateChanged -= OnBotStateChanged;
    }
}
