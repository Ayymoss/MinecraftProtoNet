@inject BotService Bot
@using Bot.Webcore.Services
@using MinecraftProtoNet.Core.Dtos
@implements IDisposable

<div class="bg-slate-900/40 backdrop-blur-2xl rounded-2xl border border-slate-800/80 shadow-xl overflow-hidden flex flex-col h-full">
    <div class="px-4 py-2.5 border-b border-slate-800/60 flex items-center justify-between bg-slate-900/20">
        <div class="flex items-center gap-2">
            <i class="ph-duotone ph-chats text-base text-emerald-400"></i>
            <h2 class="text-sm font-bold text-slate-100 tracking-tight">Chat</h2>
            @if (!Bot.PendingRedirectedChat.IsEmpty)
            {
                <span class="px-1.5 py-0.5 text-[10px] font-bold bg-emerald-500/20 text-emerald-400 rounded-md border border-emerald-500/30">
                    @Bot.PendingRedirectedChat.Count
                </span>
            }
        </div>

        <label class="flex items-center gap-2 cursor-pointer group">
            <span class="text-[9px] font-bold text-slate-500 uppercase tracking-widest group-hover:text-slate-400 transition-colors">Redirect</span>
            <div class="relative">
                <input type="checkbox" @bind="Bot.State.BotSettings.RedirectChat" class="sr-only peer"/>
                <div class="w-8 h-4 bg-slate-800 rounded-full border border-slate-700 peer-checked:bg-emerald-500/20 peer-checked:border-emerald-500/40 transition-all"></div>
                <div class="absolute left-0.5 top-0.5 w-3 h-3 bg-slate-500 rounded-full transition-all peer-checked:left-4 peer-checked:bg-emerald-400"></div>
            </div>
        </label>
    </div>

    <div class="flex-1 flex flex-col min-h-0">
        @if (!Bot.IsConnected)
        {
            <div class="flex items-center justify-center py-6 text-slate-600">
                <span class="text-xs font-medium">Awaiting connection</span>
            </div>
        }
        else if (Bot.PendingRedirectedChat.IsEmpty)
        {
            <div class="flex items-center justify-center py-6 opacity-30">
                <span class="text-[10px] font-bold uppercase tracking-widest">No messages</span>
            </div>
        }
        else
        {
            <div class="overflow-y-auto flex-1 custom-scrollbar">
                @foreach (var msg in Bot.PendingRedirectedChat.ToList())
                {
                    <div class="px-3 py-1.5 border-b border-slate-800/40 hover:bg-slate-800/20 group flex items-start gap-2 text-xs">
                        <span class="text-[10px] text-slate-600 tabular-nums shrink-0 pt-0.5">
                            @DateTimeOffset.FromUnixTimeMilliseconds(msg.Timestamp).LocalDateTime.ToString("HH:mm:ss")
                        </span>
                        <span class="text-slate-300 break-words flex-1 leading-relaxed">@msg.Message</span>
                        <div class="shrink-0 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button @onclick="() => Send(msg)"
                                    title="Send to server"
                                    class="p-1 text-emerald-500 hover:text-emerald-400 hover:bg-emerald-500/10 rounded transition-colors">
                                <i class="ph-bold ph-paper-plane-tilt text-xs"></i>
                            </button>
                            <button @onclick="() => Dismiss(msg)"
                                    title="Dismiss"
                                    class="p-1 text-slate-600 hover:text-rose-400 hover:bg-rose-500/10 rounded transition-colors">
                                <i class="ph-bold ph-x text-xs"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>

            @if (Bot.PendingRedirectedChat.Count > 1)
            {
                <div class="px-3 py-1.5 border-t border-slate-800/60 flex justify-end">
                    <button @onclick="DismissAll"
                            class="text-[10px] font-bold text-slate-500 hover:text-rose-400 uppercase tracking-wider transition-colors">
                        Clear all
                    </button>
                </div>
            }
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Bot.OnStateChanged += OnBotStateChanged;
    }

    private void OnBotStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task Send(ChatRedirectRequest msg)
    {
        await Bot.SendRedirectedChatAsync(msg);
        Bot.DismissRedirectedChat(msg);
    }

    private void Dismiss(ChatRedirectRequest msg)
    {
        Bot.DismissRedirectedChat(msg);
    }

    private void DismissAll()
    {
        Bot.PendingRedirectedChat.Clear();
        Bot.NotifyStateChanged();
    }

    public void Dispose()
    {
        Bot.OnStateChanged -= OnBotStateChanged;
    }
}
