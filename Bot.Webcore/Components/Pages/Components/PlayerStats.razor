@inject BotService Bot
@using Bot.Webcore.Services
@implements IDisposable

<div class="bg-slate-900/40 backdrop-blur-2xl rounded-3xl border border-slate-800/80 shadow-2xl p-6 flex flex-col gap-8 h-full">
    <div class="flex items-center gap-3">
        <div class="flex px-2 py-1 bg-rose-500/10 rounded-lg border border-rose-500/20">
            <i class="ph-duotone ph-heartbeat text-xl text-rose-400"></i>
        </div>
        <h2 class="text-lg font-bold text-slate-100 tracking-tight">Vitals & Navigation</h2>
    </div>

    @if (!Bot.IsConnected)
    {
        <div class="flex flex-col items-center justify-center py-6 text-slate-600 opacity-40 italic">
            <p class="text-xs font-bold uppercase tracking-widest">Awaiting vital signals...</p>
        </div>
    }
    else
    {
        var entity = Bot.State.LocalPlayer?.Entity;
        
        <div class="flex flex-col gap-6">
            <!-- Health & Hunger Indicators -->
            <div class="grid grid-cols-1 gap-6">
                <!-- Health -->
                <div class="space-y-3">
                    <div class="flex justify-between items-end px-1">
                        <div class="flex items-center gap-2">
                            <i class="ph-duotone ph-heart text-rose-500 text-base"></i>
                            <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Health</span>
                        </div>
                        <span class="text-sm font-black text-rose-400 tabular-nums tracking-tighter">
                            @(entity?.Health.ToString("F1") ?? "0") <span class="text-slate-700 font-medium">/</span> 20
                        </span>
                    </div>
                    <div class="h-2.5 bg-slate-950 rounded-full overflow-hidden border border-slate-800/50 p-0.5">
                        <div class="h-full bg-gradient-to-r from-rose-600 to-rose-400 rounded-full transition-all duration-700 ease-out shadow-[0_0_12px_rgba(225,29,72,0.3)]" 
                             style="width: @(Math.Clamp((entity?.Health ?? 0) / 20f * 100f, 0, 100))%"></div>
                    </div>
                </div>

                <!-- Hunger -->
                <div class="space-y-3">
                    <div class="flex justify-between items-end px-1">
                        <div class="flex items-center gap-2">
                            <i class="ph-duotone ph-bone text-orange-500 text-base"></i>
                            <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Hunger</span>
                        </div>
                        <span class="text-sm font-black text-orange-400 tabular-nums tracking-tighter">
                            @(entity?.Hunger ?? 0) <span class="text-slate-700 font-medium">/</span> 20
                        </span>
                    </div>
                    <div class="h-2.5 bg-slate-950 rounded-full overflow-hidden border border-slate-800/50 p-0.5">
                        <div class="h-full bg-gradient-to-r from-orange-600 to-orange-400 rounded-full transition-all duration-700 ease-out shadow-[0_0_12px_rgba(249,115,22,0.3)]" 
                             style="width: @(Math.Clamp((entity?.Hunger ?? 0) / 20f * 100f, 0, 100))%"></div>
                    </div>
                    @if (entity?.HungerSaturation > 0)
                    {
                        <div class="flex items-center gap-1.5 px-1 mt-1">
                            <i class="ph-bold ph-sparkle text-orange-500/60 text-[10px]"></i>
                            <span class="text-[10px] font-bold text-orange-500/40 uppercase tracking-tighter">Saturation: @entity.HungerSaturation.ToString("F1")</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Pathfinding Protocol Card -->
            @{
                var pathingBehavior = Bot.PathingBehavior;
                var isPathing = pathingBehavior?.IsPathing() ?? false;
                var isCalculating = pathingBehavior?.GetInProgress() != null;
                var goal = pathingBehavior?.GetGoal();
            }
            <div class="bg-slate-950/40 rounded-2xl border border-slate-800/60 p-5 shadow-inner group mt-2">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2">
                        <i class="ph-duotone ph-compass text-slate-500 group-hover:text-blue-400 transition-colors"></i>
                        <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Navigation Protocol</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full @(isPathing ? "bg-emerald-400 animate-pulse shadow-[0_0_8px_rgba(52,211,153,0.5)]" : "bg-slate-700")"></span>
                        <span class="text-[10px] font-bold @(isPathing ? "text-emerald-400" : "text-slate-600") uppercase">@(isPathing ? "Active" : "Idle")</span>
                    </div>
                </div>

                <div class="space-y-4">
                    @if (isCalculating)
                    {
                        <div class="flex items-center gap-3 p-3 bg-blue-500/5 rounded-xl border border-blue-500/20">
                            <i class="ph-duotone ph-spinner-gap animate-spin text-blue-400 text-lg"></i>
                            <span class="text-[11px] font-bold text-blue-300 uppercase tracking-tight">Calculating optimal path...</span>
                        </div>
                    }

                    @if (goal != null)
                    {
                        <div class="p-3 bg-purple-500/5 rounded-xl border border-purple-500/20">
                            <p class="text-[9px] font-black text-purple-500/60 uppercase tracking-widest mb-1.5">Primary Goal</p>
                            <div class="flex items-start gap-2">
                                <i class="ph-duotone ph-flag text-purple-400 mt-0.5"></i>
                                <p class="text-xs text-purple-200 font-bold leading-relaxed">@goal.ToString()</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
