@inject BotService Bot
@using Bot.Webcore.Services
@implements IDisposable

<div class="bg-slate-900/40 backdrop-blur-2xl rounded-3xl border border-slate-800/80 shadow-2xl overflow-hidden flex flex-col h-full">
    <!-- Header -->
    <div class="px-6 py-4 border-b border-slate-800/60 flex items-center justify-between bg-slate-900/20">
        <div class="flex items-center gap-3">
            <div class="flex px-2 py-1 bg-blue-500/10 rounded-lg border border-blue-500/20">
                <i class="ph-duotone ph-users-three text-xl text-blue-400"></i>
            </div>
            <h2 class="text-lg font-bold text-slate-100 tracking-tight">Other Players</h2>
        </div>
        
        <div class="flex items-center gap-2">
            @if (Bot.IsConnected)
            {
                <div class="px-3 py-1 bg-slate-950/50 rounded-full border border-slate-800/50 text-[10px] font-black text-slate-500 uppercase tracking-widest">
                    @GetOtherPlayerCount() Online
                </div>
            }
            @if (IsFollowing)
            {
                <button @onclick="StopFollowing"
                        class="flex items-center gap-2 px-3 py-1 bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 text-[10px] font-black uppercase tracking-widest rounded-full border border-rose-500/20 transition-all">
                    <i class="ph-bold ph-stop"></i>
                    Stop Follow
                </button>
            }
        </div>
    </div>

    <div class="p-5 flex-1 flex flex-col min-h-0">
        @if (!Bot.IsConnected)
        {
            <div class="flex flex-col items-center justify-center py-12 text-slate-600">
                <div class="w-16 h-16 rounded-full bg-slate-800/30 flex items-center justify-center mb-4 border border-slate-800/50">
                    <i class="ph-duotone ph-user-circle text-3xl opacity-20"></i>
                </div>
                <p class="font-medium">Connect to track players</p>
            </div>
        }
        else
        {
            var localUuid = Bot.State.LocalPlayer?.Uuid ?? Guid.Empty;
            var players = Bot.State.Level.GetAllPlayers()
                .Where(p => p.Uuid != localUuid)
                .ToList();

            @if (players.Count == 0)
            {
                <div class="flex-1 flex flex-col items-center justify-center py-10 opacity-40">
                    <i class="ph-duotone ph-user-circle-minus text-4xl mb-2"></i>
                    <p class="text-xs font-bold uppercase tracking-widest">Lone survivor detected</p>
                </div>
            }
            else
            {
                <div class="space-y-3 overflow-y-auto pr-2 custom-scrollbar max-h-[600px]">
                    @foreach (var player in players)
                    {
                        var entity = player.Entity;
                        <div class="flex flex-col gap-3 p-4 rounded-2xl bg-slate-900/40 border border-slate-800/60 hover:border-blue-500/30 transition-all group">
                            <div class="flex items-center gap-4">
                                <!-- Avatar -->
                                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-slate-700/50 to-slate-800/50 flex items-center justify-center border border-slate-700/30 shrink-0 relative">
                                    <i class="ph-duotone ph-user text-xl text-slate-400"></i>
                                    <span class="absolute -top-1 -right-1 w-3 h-3 bg-emerald-500 rounded-full border-2 border-slate-900 shadow-[0_0_10px_rgba(16,185,129,0.5)]"></span>
                                </div>

                                <!-- Player Info -->
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center justify-between">
                                        <span class="font-bold text-slate-200 truncate tracking-tight">@(player.Username ?? "Unknown")</span>
                                        @if (entity != null)
                                        {
                                            <div class="flex items-center gap-1.5">
                                                <i class="ph-duotone ph-heart-straight text-rose-500 text-xs"></i>
                                                <span class="text-[10px] font-black text-slate-400">@entity.Health.ToString("F0")</span>
                                            </div>
                                        }
                                    </div>

                                    @if (entity != null)
                                    {
                                        <!-- Health Progress Bar -->
                                        <div class="mt-2 h-2.5 bg-slate-950 rounded-full overflow-hidden border border-slate-800/50 p-0.5">
                                            <div class="h-full bg-gradient-to-r from-rose-600 to-rose-400 rounded-full transition-all duration-500 shadow-[0_0_8px_rgba(244,63,94,0.3)]"
                                                 style="width: @((int)Math.Clamp(entity.Health / entity.MaxHealth * 100, 0, 100))%"></div>
                                        </div>
                                    }
                                </div>
                            </div>

                            @if (entity != null)
                            {
                                <div class="flex items-center justify-between pt-2 border-t border-slate-800/40">
                                    <div class="flex items-center gap-4">
                                        <div class="flex items-center gap-1.5 text-[10px] text-slate-500">
                                            <i class="ph-duotone ph-map-pin text-slate-600"></i>
                                            @FormatPosition(entity.Position.X, entity.Position.Y, entity.Position.Z)
                                        </div>
                                        @if (entity.HeldItem.ItemId.HasValue && entity.HeldItem.ItemCount > 0)
                                        {
                                            <div class="flex items-center gap-1.5 text-[10px] font-bold text-amber-400/80">
                                                <i class="ph-duotone ph-hand-grabbing"></i>
                                                @GetItemName(entity.HeldItem.ItemId.Value)
                                            </div>
                                        }
                                    </div>

                                    <button @onclick="() => FollowPlayer(player)"
                                            class="flex items-center gap-2 px-3 py-1.5 bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 text-[10px] font-black uppercase tracking-widest rounded-lg border border-blue-500/20 transition-all opacity-0 group-hover:opacity-100 shadow-lg shadow-blue-500/5">
                                        <i class="ph-duotone ph-footprints text-base"></i>
                                        Follow
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>
